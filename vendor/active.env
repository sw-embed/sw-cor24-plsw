# Single source of truth for which vendored toolchain version is
# active. Loaded by justfile via `set dotenv-load`, sourced by
# scripts/vendor-fetch.sh. Bumping a tool is one line here plus
# a new versioned subdirectory under vendor/<tool>/.
#
# See docs/vendor-plan.md for the upgrade workflow.

SW_CX24_VERSION=v0.1.0
SW_ASX24_VERSION=v0.1.0
SW_EM24_VERSION=v0.1.0
