/* tcb.msw -- Task Control Block (COR24) */

DCL 1 TCB BASED,
  3 TCBEYE(4)  CHAR,          /* 'TCB ' eyecatcher */
  3 TCBVER     BYTE,
  3 TCBFLAGS   BYTE,
  3 TCBNEXT    PTR,           /* next TCB in chain */
  3 TCBPREV    PTR,           /* prev TCB in chain */
  3 TCBASCB    PTR,           /* owning ASCB */
  3 TCBSTATE   BYTE,
  3 TCBPRI     BYTE;
/* size = 4 + 1 + 1 + 3 + 3 + 3 + 1 + 1 = 17 */
